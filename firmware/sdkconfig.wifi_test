# WiFi throughput test sdkconfig
# Based on sdkconfig.defaults but with BLE disabled and WiFi/HTTP enabled

# PSRAM
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y

# USB serial/JTAG console (built-in on XIAO ESP32S3)
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# Task watchdog
CONFIG_ESP_TASK_WDT_TIMEOUT_S=15

# Main task stack
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

# Disable BLE — we're WiFi only for this test
CONFIG_BT_ENABLED=n

# WiFi — bump buffers for throughput
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=16
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=32
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=32
CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=y
CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=y
CONFIG_ESP_WIFI_TX_BA_WIN=16
CONFIG_ESP_WIFI_RX_BA_WIN=16

# LWIP — bump for HTTP performance
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=16384
CONFIG_LWIP_TCP_RECVMBOX_SIZE=32
CONFIG_LWIP_UDP_RECVMBOX_SIZE=32
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=64
