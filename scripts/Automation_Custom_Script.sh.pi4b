#!/usr/bin/env bash
# Helios first-boot install — Raspberry Pi 4B edition.
#
# Runs automatically after DietPi's base install on first boot.
# By this point: network is up, apt packages installed (including bluez
# since we put it in AUTO_SETUP_APT_INSTALLS), SSH running.
#
# Pi 4B uses the Broadcom BCM43455 WiFi+BT chip — bluez Just Works, no
# vendor drivers. Bluez drives the A2DP link to the MT speaker directly;
# the pendant talks to this Pi over WiFi HTTP.
#
# This script:
#   1. Clones the Helios repo
#   2. Creates a Python venv with server deps
#   3. Installs helios-server systemd unit (DISABLED by default)
#
# Logs: /var/tmp/dietpi/logs/dietpi-automation_custom_script.log

set -euo pipefail

HELIOS_REPO="https://github.com/Kaden-Schutt/project-helios.git"
HELIOS_BRANCH="main"
HELIOS_DIR="/root/project-helios"

log() { echo "[helios-firstboot] $*"; }

# --- 1. Make sure bluez + bluez-alsa are there for MT A2DP output ---
if ! dpkg -l bluez 2>/dev/null | grep -q '^ii'; then
    log "bluez not installed by AUTO_SETUP_APT_INSTALLS, installing now..."
    DEBIAN_FRONTEND=noninteractive apt-get install -y \
        bluez bluez-tools bluez-alsa-utils avahi-daemon avahi-utils
fi

# --- 2. Clone repo ---
log "Cloning Helios repo..."
if [[ ! -d "$HELIOS_DIR/.git" ]]; then
    git clone --depth 1 --branch "$HELIOS_BRANCH" "$HELIOS_REPO" "$HELIOS_DIR"
fi

# --- 3. Python venv + deps ---
log "Creating Python venv..."
python3 -m venv "$HELIOS_DIR/.venv"
"$HELIOS_DIR/.venv/bin/pip" install --upgrade pip wheel
"$HELIOS_DIR/.venv/bin/pip" install \
    httpx websockets python-dotenv \
    anthropic numpy fastapi uvicorn \
    bleak opuslib

# --- 4. helios-server systemd unit (disabled by default) ---
log "Installing helios-server.service (DISABLED)..."
cat > /etc/systemd/system/helios-server.service <<EOF
[Unit]
Description=Helios Voice + Vision Server (WiFi HTTP)
After=bluetooth.service network-online.target
Wants=bluetooth.service

[Service]
Type=simple
User=root
WorkingDirectory=$HELIOS_DIR
ExecStart=$HELIOS_DIR/.venv/bin/python server.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
# NOT enabled — start manually after placing .env + pairing MT speaker:
#   scp .env root@helios.local:/root/project-helios/.env
#   bluetoothctl   # scan, pair, trust, connect the MT speaker
#   systemctl start helios-server

log "======================================"
log "Helios first-boot install complete"
log "======================================"
log ""
log "Next steps:"
log "  1. scp .env root@helios.local:/root/project-helios/.env"
log "  2. bluetoothctl → pair + connect the MT BT speaker"
log "  3. systemctl start helios-server"
log "  4. journalctl -u helios-server -f"
log ""
log "Pi reachable as helios.local on whatever WiFi it joined."
